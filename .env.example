# Docker Compose 环境配置示例
# 复制此文件为 .env 并根据需要修改

# MySQL 配置
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=shop
MYSQL_USER=shop
MYSQL_PASSWORD=shop123

# Redis 配置
REDIS_PASSWORD=

# 后端配置
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# 前端配置
FRONTEND_PORT=3000

# Nginx 配置
NGINX_PORT=80
NGINX_WORKER_PROCESSES=auto

# 时区
TZ=Asia/Shanghai
