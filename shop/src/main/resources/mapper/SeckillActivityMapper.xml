<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.shop.mapper.SeckillActivityMapper">

    <resultMap id="seckillActivityMap" type="SeckillActivity">
        <id column="id" property="id"/>
        <result column="product_id" property="productId"/>
        <result column="activity_name" property="activityName"/>
        <result column="seckill_price" property="seckillPrice"/>
        <result column="total_stock" property="totalStock"/>
        <result column="remaining_stock" property="remainingStock"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectById" parameterType="Long" resultMap="seckillActivityMap">
        SELECT id, product_id, activity_name, seckill_price, total_stock, remaining_stock, start_time, end_time, status, create_time, update_time
        FROM seckill_activity
        WHERE id = #{id}
    </select>

    <update id="decreaseRemainingStock">
        UPDATE seckill_activity
        SET remaining_stock = remaining_stock - #{quantity},
            update_time = #{updateTime}
        WHERE id = #{id}
          AND remaining_stock >= #{quantity}
    </update>

</mapper>
